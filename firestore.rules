rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.token.email));
    }

    function currentUserRole() {
      return currentUserProfile().data.role != null
        ? currentUserProfile().data.role
        : currentUserProfile().data.rol;
    }

    function hasRole(role) {
      return signedIn()
        && currentUserProfile().exists()
        && currentUserRole() == role;
    }

    function adminOrEmployee() {
      return hasRole('admin') || hasRole('employee');
    }

    match /parked_vehicles/{docId} {
      allow read: if adminOrEmployee();
      allow create: if adminOrEmployee();
      allow update: if adminOrEmployee();
      allow delete: if hasRole('admin');
    }

    match /subscribers/{docId} {
      allow read: if adminOrEmployee();
      allow create, update, delete: if hasRole('admin');
    }

    match /history/{docId} {
      allow read: if hasRole('admin');
      allow create: if adminOrEmployee();
      allow update, delete: if false;
    }

    match /usuarios/{email} {
      allow read: if signedIn();
      allow write: if hasRole('admin');
    }

    match /artifacts/public/data/settings {
      allow read: if signedIn();
      allow write: if hasRole('admin');
    }
  }
}
